{
  "name": "arabic-keyboard-mapper",
  "displayName": "Arabic Keyboard Mapper",
  "description": "Map QWERTY keyboard to Arabic characters",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.65.0"
  },
  "categories": ["Other"],
  "publisher": "user",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/arabic-keyboard-mapper"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "arabicKeyboardMapper.toggleArabic",
        "title": "Toggle Arabic Keyboard"
      },
      {
        "command": "arabicKeyboardMapper.enableArabic",
        "title": "Enable Arabic Keyboard"
      },
      {
        "command": "arabicKeyboardMapper.disableArabic",
        "title": "Disable Arabic Keyboard"
      }
    ],
    "keybindings": [
      {
        "command": "arabicKeyboardMapper.toggleArabic",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Arabic Keyboard Mapper",
      "properties": {
        "arabicKeyboardMapper.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Arabic keyboard mapping"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "watch": "npm run esbuild-base -- --sourcemap --watch",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.65.0",
    "@types/node": "^16.0.0",
    "typescript": "^4.0.0",
    "esbuild": "^0.13.0"
  }
}
